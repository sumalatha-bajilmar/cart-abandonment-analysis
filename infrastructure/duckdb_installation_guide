# --------------------  Duck DB set up on Ubuntu -------------------- 

Reference documents: 
https://duckdb.org/install/?platform=linux&environment=cli
https://github.com/duckdb/duckdb

# Update package index and install unzip
sudo apt update && sudo apt install -y unzip wget

# Download the latest CLI
wget https://github.com/duckdb/duckdb/releases/download/v1.4.3/duckdb_cli-linux-amd64.zip

# Unzip the file
unzip duckdb_cli-linux-amd64.zip

# Make the file executable and move it to system path
chmod +x duckdb
sudo mv duckdb /usr/local/bin/duckdb

# Verify the installation
duckdb -version

# Connect to DuckDB Console
duckdb my_database.db

#  Install and load the AWS connector package
INSTALL aws;
LOAD aws;

# Automatically import the EC2 instance profile IAM credentials
CALL load_aws_credentials();

# Set the target bucket deployment region (e.g., us-east-1)
SET s3_region='ap-south-2';


# -------------------- Run sample query --------------------
Run the following command to enter into DuckDB command line interface
duckdb

# execute the SQL with correct S3 file in the DuckDB CLI
SELECT *  FROM read_parquet('s3://your-bucket-name/path/*.parquet')  LIMIT 10;
